    "html": "<html lang=\"en\"><head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0\">\n    <meta name=\"mobile-web-app-capable\" content=\"yes\">\n    <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\">\n    <link rel=\"shortcut icon\" href=\"favicon.ico\" type=\"image/x-icon\">\n    <link rel=\"apple-touch-icon\" href=\"apple-touch-icon.png\">\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Zen+Dots&amp;display=swap\" rel=\"stylesheet\">\n    <title>Sébastien Lempens :: Web Engineer :: Portfolio</title>\n    <meta name=\"description\" content=\"I'm Sébastien Lempens, a french 'Gen X' Web Engineer. Throughout my career, I have worked on multiple sized projects in various roles, including Project Manager, Designer and Front/Back-end Developer.\">\n    <style>\n      body {\n        background-color: #e4e4e4;\n      }\n      :root {\n        --france-color: #e4e4e4;\n        --luxembourg-color: #e4e4e4;\n        --belgium-color: #e4e4e4;\n      }\n      #preloader {\n        --progress: 0;\n        position: fixed;\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        background-color: transparent;\n        z-index: 999999999;\n        pointer-events: none;\n        display: grid;\n        place-content: center;\n        &.preloader--france {\n          background-color: var(--france-color);\n        }\n        &.preloader--luxembourg {\n          background-color: var(--luxembourg-color);\n        }\n        &.preloader--belgium {\n          background-color: var(--belgium-color);\n        }\n        & code {\n          display: block;\n          position: absolute;\n          z-index: 0;\n          bottom: auto;\n          left: 50%;\n          transform: translateX(-50%);\n          font-family: \"Zen Dots\", sans-serif;\n          font-size: 15vmin;\n          letter-spacing: 0.15em;\n          opacity: 0.05;\n          transition: opacity 1200ms ease;\n        }\n        & > div.motorbike {\n          position: relative;\n          z-index: 1;\n          left: 0;\n          top: -55px;\n          opacity: 0;\n          transform-origin: center bottom;\n          transform: scale(0.8);\n          transition: opacity 600ms cubic-bezier(0.22, 0.61, 0.36, 1), left 600ms cubic-bezier(0.22, 0.61, 0.36, 1);\n          &::after,\n          &::before {\n            content: \"\";\n            display: block;\n            width: 88px;\n            height: 88px;\n            position: absolute;\n            z-index: 0;\n            bottom: -20px;\n            background-image: url(\"/image/motorbike-wheel.png\");\n            animation: wheelAnimation 220ms linear infinite;\n          }\n          &::after {\n            left: 10px;\n          }\n          &::before {\n            right: -10px;\n          }\n\n          & > img {\n            animation: motocycleAnimation 15ms infinite linear;\n            position: relative;\n            z-index: 1;\n          }\n          &.active {\n            opacity: 1;\n            left: 0;\n            &::after {\n              opacity: 1;\n            }\n          }\n        }\n        & > .city {\n          content: \"\";\n          display: block;\n          position: absolute;\n          top: 50%;\n          left: 50%;\n          transform: translateX(-50%) translateY(-50%);\n          width: 1000px;\n          height: 186px;\n          background-image: url(\"/image/city.png\");\n          mask: radial-gradient(circle, black 25%, transparent 75%);\n          opacity: 0.25;\n          background-repeat: repeat-x;\n          background-position: 0 0;\n          animation: cityAnimation 5s linear infinite;\n          transition: opacity 1200ms cubic-bezier(0.22, 0.61, 0.36, 1) 450ms;\n        }\n        & > .preloader-enter {\n          position: absolute;\n          top: 50%;\n          left: 50%;\n          transform: translate(-50%, -50%);\n          z-index: 999;\n          display: flex;\n          flex-direction: column;\n          text-align: center;\n          &::before {\n            content: \"\";\n            display: block;\n            width: 25dvw;\n            height: 105px;\n            transform: translateY(5px);\n            background-image: url(\"/image/preload-monuments.png\");\n            background-position: 0 0;\n            margin: 0 auto;\n            transition: clip-path 500ms ease 50ms;\n            clip-path: inset(0 0 0 100%);\n            animation: monumentsAnimation 8s linear infinite;\n          }\n          & > .button-start {\n            display: block;\n            position: relative;\n            background-color: transparent;\n            border: 2px solid #d3b3c9;\n            min-width: 25dvw;\n            background: #8b7082;\n            text-transform: uppercase;\n            color: white;\n            border-radius: 3px;\n            padding: 10px 20px;\n            font-size: 1.5em;\n            cursor: pointer;\n            margin: 0 auto;\n            transition: background-color 300ms ease;\n            font-family: \"zen dots\", sans-serif;\n            text-align: center;\n            text-decoration: none;\n            pointer-events: fill;\n            clip-path: inset(0 100% 0px 0);\n            transition: clip-path 500ms ease-out 50ms, background-color 300ms ease;\n            &::after {\n              content: \"\";\n              display: block;\n              position: absolute;\n              top: -115px;\n              left: 50%;\n              width: 300px;\n              background: radial-gradient(ellipse at center, #f0eff0 -60%, transparent 55%) padding-box;\n              mix-blend-mode: plus-lighter;\n              height: 300px;\n              opacity: 0.6;\n              transform: translateX(-50%) scale(1.5);\n            }\n            &:hover {\n              background-color: #5c4655;\n              color: #fff;\n            }\n          }\n          & > p {\n            clip-path: inset(0 100% 0 0);\n            transition: clip-path 500ms ease-out 50ms;\n            font-size: medium;\n            margin: 5px 0;\n            letter-spacing: 0.2em;\n            &:nth-of-type(1) {\n              margin-top: 25px;\n            }\n          }\n        }\n        &.end {\n          & > div.motorbike {\n            transition-duration: 1200ms;\n            left: 400px;\n            opacity: 0;\n          }\n          & code {\n            opacity: 0;\n          }\n          & > .city,\n          &::after {\n            opacity: 0;\n          }\n          & > .preloader-enter {\n            &::before {\n              opacity: 0.85;\n              clip-path: inset(0 0 0 0);\n              pointer-events: none;\n            }\n            & > .button-start {\n              clip-path: inset(0 0 0 0);\n            }\n            & > p {\n              clip-path: inset(0 0 0 0);\n              pointer-events: none;\n            }\n          }\n        }\n      }\n      html.html--loaded #preloader {\n        &::after {\n          display: none;\n        }\n      }\n      #awards {\n        position: fixed;\n        width: 100%;\n        bottom: 10dvh;\n        z-index: 999999999;\n        pointer-events: painted;\n        transition: opacity 1200ms ease;\n        mix-blend-mode: darken;\n        & > div {\n          display: flex;\n          align-items: center;\n          gap: 50px;\n          justify-content: center;\n        }\n        &.end {\n          opacity: 0;\n          pointer-events: none;\n          & > div {\n            pointer-events: none;\n          }\n        }\n      }\n      #cookie {\n        position: fixed;\n        bottom: 0;\n        left: 0;\n        width: 100%;\n        background-color: hsla(0, 0%, 0%, 0.6);\n        color: white;\n        padding: 10px;\n        text-align: center;\n        z-index: 999999999999999999999999;\n        transform: translateY(100%);\n        transition: transform 1200ms ease;\n        &.disabled {\n          transform: translateY(100%) !important;\n        }\n        & button {\n          font-family: \"zen dots\", sans-serif;\n          background-color: hsla(0, 0%, 0%, 0.6);\n          color: white;\n          border: 1px solid white;\n          padding: 5px 20px;\n          cursor: pointer;\n          transition: background-color 300ms ease;\n          &:hover {\n            transition: transform 800ms ease;\n            background-color: hsla(0, 0%, 0%, 0.1);\n          }\n        }\n      }\n      #preloader.end + #cookie,\n      html.html--loaded #cookie:not(.disabled) {\n        transform: none;\n      }\n      @keyframes motocycleAnimation {\n        from {\n          transform: scaleY(0.98);\n        }\n        to {\n          transform: scaleY(1);\n        }\n      }\n      @keyframes cityAnimation {\n        to {\n          background-position-x: -2000px;\n        }\n      }\n      @keyframes wheelAnimation {\n        to {\n          transform: rotate(360deg);\n        }\n      }\n      @keyframes monumentsAnimation {\n        to {\n          background-position-x: calc((80px * 3) * -1);\n        }\n      }\n      @media screen and (max-width: 430px) {\n        #preloader {\n          & > .city {\n            top: 40dvh;\n          }\n          & code {\n            font-size: 40vmin;\n          }\n          & > div.motorbike {\n            transform: scale(0.5);\n            top: -115px;\n          }\n          & > .preloader-enter {\n            width: 95vw;\n            text-align: center;\n            & > a.button-start {\n              min-width: 100%;\n            }\n            &::before {\n              width: 100%;\n            }\n            & > p {\n              font-size: medium;\n            }\n          }\n        }\n        html.html--loaded #preloader {\n          &.end {\n            & > div.motorbike {\n              left: 100vw;\n            }\n          }\n        }\n        #awards {\n          bottom: 3dvh;\n          & > div {\n            gap: 2px 20px;\n            flex-wrap: wrap;\n            max-width: 100vw;\n            margin: 0 auto;\n            transform: scale(0.8);\n          }\n        }\n        #cookie,\n        #cookie button {\n          font-size: small;\n        }\n      }\n    </style>\n    <script type=\"module\" crossorigin=\"\" src=\"/assets/index-4d5058b7.js\"></script>\n    <link rel=\"stylesheet\" href=\"/assets/index-9c19f8ed.css\">\n  <link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/CountryFrance-f00480c0.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/index-4d5058b7.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/useMouse-3146b371.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/HtmlTitle-55ce96e9.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/Billboard-db8401b8.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/Html-1c2e1576.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/useAnimation-a2a41dc0.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/deprecated-c7a578db.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/shapes-304707e1.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/Model-7da76081.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/CountryLuxembourg-00e33653.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/CountryBelgium-feed6193.js\"><link rel=\"modulepreload\" as=\"script\" crossorigin=\"\" href=\"/assets/Cloud-908fad59.js\"></head>\n  <body>\n    <div id=\"preloader